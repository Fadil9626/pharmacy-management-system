# Remedy — backend environment
# Copy to .env and fill in real values. Never commit the real .env.

# API port
PORT=5190

# PostgreSQL connection (see docker-compose.yml for local defaults)
DATABASE_URL=postgresql://pharmacy_user:pharmacy_pass@127.0.0.1:5437/pharmacy_db

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Shared key the Control Center uses to manage this instance (modules, plans).
# Must match the admin_api_key set on the subscriber in the Control Center.
ADMIN_API_KEY=change-me-to-a-random-admin-key
